{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/health",
      "destination": "/api/health"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/server?path=:path*"
    }
  ],
  "functions": {
    "api/health.js": {
      "maxDuration": 10,
      "memory": 128
    },
    "api/server.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  }
}
