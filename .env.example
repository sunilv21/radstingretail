# Radsting POS + ERP — environment config template.
# Copy this file to .env and fill in real values. .env is gitignored.

# ---- MongoDB ----
# Atlas connection string. Create a free M0 cluster at mongodb.com/cloud/atlas,
# add a DB user, allow network access, then paste the Node.js driver URI here.
# The DB name (pos_erp) goes before the "?" — create it on first connect.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/pos_erp?retryWrites=true&w=majority

# ---- Auth ----
# 32+ random chars. Rotate quarterly in production.
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string

# ---- App ----
# Local Express server port. Vercel ignores this because API routes run as
# serverless functions.
PORT=5000

# Do not set NODE_ENV manually on Vercel. Vercel/Next set it to production.

# Public base URL used in WhatsApp / email share links.
# Local:      http://localhost:3000
# Production: https://radstingretail.vercel.app or your custom domain
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Browser API base URL.
# Local dev with separate Express server:
# NEXT_PUBLIC_API_URL=http://localhost:5000/api
# Vercel same-origin deployment:
# NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Production CORS allow-list for cross-origin API callers. If frontend and API
# are on the same Vercel domain, this can be omitted. If using a custom domain,
# set it to that exact origin, for example:
# CORS_ORIGIN=https://yourdomain.com
# CORS_ORIGIN=

# Optional vendor contact info shown in subscription/billing/support UI.
# NEXT_PUBLIC_VENDOR_EMAIL=support@example.com
# NEXT_PUBLIC_VENDOR_PHONE=+919999999999
# NEXT_PUBLIC_VENDOR_WHATSAPP=919999999999
# NEXT_PUBLIC_VENDOR_PAY_URL=https://your-payment-link.example
# NEXT_PUBLIC_VENDOR_WEBSITE=https://example.com
# NEXT_PUBLIC_APP_VERSION=1.0.0

# ---- WhatsApp (optional — live per-store in Settings UI) ----
# Leave blank; merchants set their own credentials via the Settings page. These
# env vars are only used if you want a fallback or dev override.
# WHATSAPP_DEFAULT_COUNTRY_CODE=91
