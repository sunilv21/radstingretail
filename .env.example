# Radsting POS + ERP — environment config template.
# Copy this file to .env and fill in real values. .env is gitignored.

# ---- MongoDB ----
# Atlas connection string. Create a free M0 cluster at mongodb.com/cloud/atlas,
# add a DB user, allow network access, then paste the Node.js driver URI here.
# The DB name (pos_erp) goes before the "?" — create it on first connect.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/pos_erp?retryWrites=true&w=majority

# ---- Auth ----
# 32+ random chars. Rotate quarterly in production.
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string

# ---- App ----
PORT=5000
NODE_ENV=development

# Public base URL used in WhatsApp / email share links. For local dev keep as
# localhost:3000; in production set to your real https:// domain.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- WhatsApp (optional — live per-store in Settings UI) ----
# Leave blank; merchants set their own credentials via the Settings page. These
# env vars are only used if you want a fallback or dev override.
# WHATSAPP_DEFAULT_COUNTRY_CODE=91
